      },
      "padding": {
        "$type": "dimension",
        "$value": {
          "value": 12,
          "unit": "px"
        }
      },
      "transition": {
        "$value": "opacity 100ms ease-in"
      },
      "$extensions": {
        "design.md": {
          "states": {
            "hover": {
              "backgroundColor": "#ffffff1a"
            },
            "focus-visible": {
              "outline": "2px solid {colors.secondary}"
            },
            "disabled": {
              "textColor": "#c4c7c8",
              "cursor": "not-allowed"
            }
          },
          "interactive": true
        }
      }
    }
  }
}
